# Copy to .env (cp .env.example .env) and adjust for your Firebase project.
# Console: Firebase → Project settings → Your apps → Web app config

# Firebase (required for a different project; if empty, embedded defaults in src/lib/firebase.ts apply)
VITE_FIREBASE_API_KEY=AIzaSyAk7tg62sbb0NgbrHRT1ONpFP9Y6GRozdE
VITE_FIREBASE_AUTH_DOMAIN=marketflow-cf7f1.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=marketflow-cf7f1
VITE_FIREBASE_STORAGE_BUCKET=marketflow-cf7f1.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=77892839271
VITE_FIREBASE_APP_ID=1:77892839271:web:9528eec9d27b196a8871c2
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=G-XVRWX6VBEK

# Firestore: in-memory local cache only (stable with Vite; no Firestore offline IndexedDB).
# Long-polling auto-detect is OFF unless you set true (corporate proxy only).
# VITE_FIRESTORE_USE_LONG_POLLING=true

# Email — in the browser SPA, SendGrid/Mailgun/SMTP calls fail (CORS / no /api). Use "console" unless you add a backend.
# VITE_ALLOW_BROWSER_EMAIL=true  # not recommended; only if you know what you're doing
VITE_EMAIL_PROVIDER=console
VITE_EMAIL_FROM=noreply@yourdomain.com
VITE_EMAIL_FROM_NAME=MarketFlow
VITE_SENDGRID_API_KEY=

# App URL (for email links)
VITE_APP_URL=http://localhost:8080

# Public site URL (canonical domain for SEO: index.html, sitemap, og:image — update after deploy)
VITE_PUBLIC_SITE_URL=https://app.marketflow.com
