rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    // Assets folder - users can upload to their own folder
    match /assets/{userId}/{category}/{fileName} {
      // Allow read if authenticated
      allow read: if request.auth != null;
      
      // Allow write (upload) if:
      // 1. User is authenticated
      // 2. User is uploading to their own folder (userId matches auth.uid)
      // 3. File size is less than 25MB
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
      
      // Allow delete if user owns the file
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}




